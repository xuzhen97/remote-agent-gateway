{
  "name": "remote-agent-gateway",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "pnpm --filter @rag/server dev",
    "dev:client": "pnpm --filter @rag/client dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build:dist": "tsx scripts/build-all.ts",
    "build:dist:server": "tsx scripts/build-server.ts",
    "build:dist:client": "tsx scripts/build-client.ts",
    "test:e2e": "tsx scripts/e2e-test.ts",
    "test:e2e:keep": "tsx scripts/e2e-test.ts --keep",
    "test:e2e:verbose": "tsx scripts/e2e-test.ts --verbose",
    "download:frp": "tsx scripts/download-frp.ts",
    "test:frp": "tsx scripts/test-frp.ts",
    "test:frp:keep": "tsx scripts/test-frp.ts --no-start",
    "test:frp:verbose": "tsx scripts/test-frp.ts --verbose"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
