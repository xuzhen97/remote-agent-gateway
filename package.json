{
  "name": "remote-agent-gateway",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "clean": "tsx scripts/clean.ts",
    "compile": "pnpm -r build",
    "build": "tsx scripts/build-all.ts",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "package": "tsx scripts/package.ts",
    "version:sync": "tsx scripts/sync-version.ts",
    "version:patch": "tsx scripts/sync-version.ts --bump patch",
    "version:minor": "tsx scripts/sync-version.ts --bump minor",
    "version:major": "tsx scripts/sync-version.ts --bump major"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
