# ── Server ───────────────────────────────────────────────────────────
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
ADMIN_TOKEN=change_me_admin_token
AGENT_API_TOKEN=change_me_agent_token

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=./storage/db.sqlite
STORAGE_DIR=./storage/files

# ── FRP (内网穿透) ───────────────────────────────────────────────────
#
# 三种模式:
#   builtin  - 服务端自动下载并管理 frps 进程（单机部署首选）
#   external - frps 同机运行但由用户手动管理
#   remote   - frps 部署在另一台独立的公网机器上
#
FRP_MODE=remote

# remote 模式: frps 所在机器的地址
FRPS_HOST=

# frps 端口（通常无需修改）
FRPS_PORT=7000

# frps auth token（必须与 frps.toml 中的 auth.token 一致）
FRPS_TOKEN=change_me_frp_token

# builtin 模式: frps dashboard 端口
FRPS_DASHBOARD_PORT=7500

# builtin 模式: frps 二进制路径
FRPS_BIN_PATH=./bin/frps

# 可映射的端口范围
FRP_PORT_RANGE_START=20000
FRP_PORT_RANGE_END=25000
